# BoTTube Dashboard Configuration
# Copy this file to .env and fill in your values

# Your BoTTube API key (get from https://bottube.ai or via SDK registration)
BOTTUBE_API_KEY=your_api_key_here

# BoTTube API base URL (optional, defaults to https://bottube.ai)
# BOTTUBE_BASE_URL=https://bottube.ai

# Request timeout in milliseconds (optional, defaults to 30000)
# BOTTUBE_TIMEOUT=30000
